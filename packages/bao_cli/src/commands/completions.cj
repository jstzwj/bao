// 严格翻译自: src/cli/shell_completions.zig, src/cli/add_completions.zig
// bao completions - Shell 补全生成
package bao_cli

import bao_core.*
import bao_collections.*
import bao_io.*
import bao_path.*
import bao_sys.*

// ============================================================================
// completions 命令 - 对应 bun completions
// 严格翻译自: src/cli/shell_completions.zig (Shell, completions)
// ============================================================================

/// Shell 类型
/// 严格翻译自: src/cli/shell_completions.zig Shell enum
public enum ShellType {
    | Unknown
    | Bash
    | Zsh
    | Fish
    | Pwsh     // PowerShell
}

/// Shell 补全生成器
/// 严格翻译自: src/cli/shell_completions.zig
public class CompletionsGenerator {
    /// 命令列表
    public var commands: ArrayList<String>
    /// 命令描述列表
    public var descriptions: ArrayList<String>
    /// 全局标志列表
    public var flags: ArrayList<String>
    /// 当前 shell
    public var shell: ShellType

    public init() {
        commands = ArrayList<String>()
        descriptions = ArrayList<String>()
        flags = ArrayList<String>()
        shell = ShellType.Unknown
    }

    /// 从 SHELL 环境变量检测 shell 类型
    // 严格翻译自: src/cli/shell_completions.zig Shell.fromEnv
    public static func detectShell(): ShellType {
        let shellPath = Sys.getEnv("SHELL") ?? ""
        if (shellPath.isEmpty()) {
            // Windows: 检查 PSModulePath 或 COMSPEC
            let comspec = Sys.getEnv("COMSPEC") ?? ""
            if (comspec.contains("powershell") || comspec.contains("pwsh")) {
                return ShellType.Pwsh
            }
            return ShellType.Unknown
        }

        let basename = Path.basename(shellPath)
        if (basename == "bash") {
            return ShellType.Bash
        } else if (basename == "zsh") {
            return ShellType.Zsh
        } else if (basename == "fish") {
            return ShellType.Fish
        } else if (basename == "pwsh" || basename == "powershell") {
            return ShellType.Pwsh
        }
        return ShellType.Unknown
    }

    /// 从字符串检测 shell 类型
    public static func shellFromString(s: String): ShellType {
        let lower = s.toLower()
        if (lower == "bash") {
            return ShellType.Bash
        } else if (lower == "zsh") {
            return ShellType.Zsh
        } else if (lower == "fish") {
            return ShellType.Fish
        } else if (lower == "pwsh" || lower == "powershell") {
            return ShellType.Pwsh
        }
        return ShellType.Unknown
    }

    /// 生成补全脚本
    // 严格翻译自: src/cli/shell_completions.zig print
    public func generate(): String {
        if (commands.size == 0) {
            populateDefaultCommands()
        }

        return match (shell) {
            case ShellType.Bash => generateBash()
            case ShellType.Zsh => generateZsh()
            case ShellType.Fish => generateFish()
            case ShellType.Pwsh => generatePwsh()
            case ShellType.Unknown => ""
        }
    }

    /// 填充默认命令列表
    private func populateDefaultCommands(): Unit {
        let defaultCommands = [
            ("run", "Run a JavaScript/TypeScript file or package.json script"),
            ("build", "Bundle JavaScript/TypeScript files"),
            ("install", "Install dependencies from package.json"),
            ("add", "Add a dependency to package.json"),
            ("remove", "Remove a dependency from package.json"),
            ("update", "Update dependencies"),
            ("test", "Run tests"),
            ("init", "Create a new project"),
            ("create", "Create a new project from a template"),
            ("upgrade", "Upgrade Bao to the latest version"),
            ("x", "Execute a package binary"),
            ("completions", "Generate shell completions"),
        ]
        for ((cmd, desc) in defaultCommands) {
            commands.append(cmd)
            descriptions.append(desc)
        }

        let defaultFlags = [
            "--version", "-v", "--help", "-h", "--verbose",
            "--silent", "--cwd", "--env-file", "--config"
        ]
        for (flag in defaultFlags) {
            flags.append(flag)
        }
    }

    /// 生成 Bash 补全
    // 严格翻译自: src/cli/completions-bash
    private func generateBash(): String {
        var sb = StringBuilder()
        sb.append("# Bao shell completions for bash\n")
        sb.append("# Generated by `bao completions bash`\n")
        sb.append("_bao_completion() {\n")
        sb.append("  local cur prev words cword\n")
        sb.append("  _init_completion || return\n")
        sb.append("\n")
        sb.append("  # Commands\n")
        sb.append("  local commands='")

        var first = true
        for (cmd in commands) {
            if (!first) { sb.append(" ") }
            sb.append(cmd)
            first = false
        }
        sb.append("'\n")

        sb.append("\n")
        sb.append("  # Global flags\n")
        sb.append("  local flags='")
        first = true
        for (flag in flags) {
            if (!first) { sb.append(" ") }
            sb.append(flag)
            first = false
        }
        sb.append("'\n")

        sb.append("\n")
        sb.append("  if [[ ${cword} -eq 1 ]]; then\n")
        sb.append("    COMPREPLY=($(compgen -W \"${commands} ${flags}\" -- ${cur}))\n")
        sb.append("    return 0\n")
        sb.append("  fi\n")

        // 子命令特定补全
        sb.append("\n")
        sb.append("  case ${words[1]} in\n")
        sb.append("    run)\n")
        sb.append("      # 补全 package.json scripts\n")
        sb.append("      if [[ -f package.json ]]; then\n")
        sb.append("        local scripts=$(bao run 2>/dev/null | grep '^  ' | awk '{print $1}')\n")
        sb.append("        COMPREPLY=($(compgen -W \"${scripts}\" -- ${cur}))\n")
        sb.append("      fi\n")
        sb.append("      return 0\n")
        sb.append("      ;;\n")
        sb.append("    build|test)\n")
        sb.append("      COMPREPLY=($(compgen -f -- ${cur}))\n")
        sb.append("      return 0\n")
        sb.append("      ;;\n")
        sb.append("    install|add|remove|update)\n")
        sb.append("      COMPREPLY=($(compgen -W \"${flags}\" -- ${cur}))\n")
        sb.append("      return 0\n")
        sb.append("      ;;\n")
        sb.append("  esac\n")
        sb.append("}\n")
        sb.append("\n")
        sb.append("complete -F _bao_completion bao\n")
        return sb.toString()
    }

    /// 生成 Zsh 补全
    // 严格翻译自: src/cli/completions-zsh
    private func generateZsh(): String {
        var sb = StringBuilder()
        sb.append("#compdef bao\n")
        sb.append("# Bao shell completions for zsh\n")
        sb.append("# Generated by `bao completions zsh`\n")
        sb.append("\n")
        sb.append("#compdef bao\n")
        sb.append("function _bao() {\n")
        sb.append("  local -a commands\n")
        sb.append("  commands=(\n")

        for (i in 0..commands.size) {
            let desc = if (i < descriptions.size) { descriptions[i] } else { "" }
            sb.append("    '${commands[i]}:${desc}'\n")
        }
        sb.append("  )\n")

        sb.append("\n")
        sb.append("  _arguments -C \\\n")
        sb.append("    '1:command:->command' \\\n")
        sb.append("    '*::arg:->args'\n")

        sb.append("\n")
        sb.append("  case $state in\n")
        sb.append("    command)\n")
        sb.append("      _describe 'command' commands\n")
        sb.append("      ;;\n")
        sb.append("    args)\n")
        sb.append("      case $words[1] in\n")
        sb.append("        run)\n")
        sb.append("          _arguments '*:script:_files'\n")
        sb.append("          ;;\n")
        sb.append("        build)\n")
        sb.append("          _arguments '*:entry:_files'\n")
        sb.append("          ;;\n")
        sb.append("      esac\n")
        sb.append("      ;;\n")
        sb.append("  esac\n")
        sb.append("}\n")
        sb.append("\n")
        sb.append("_bao \"$@\"\n")
        return sb.toString()
    }

    /// 生成 Fish 补全
    // 严格翻译自: src/cli/completions-fish
    private func generateFish(): String {
        var sb = StringBuilder()
        sb.append("# Bao shell completions for fish\n")
        sb.append("# Generated by `bao completions fish`\n")
        sb.append("\n")
        sb.append("# Disable file completions by default\n")
        sb.append("complete -c bao -f\n")
        sb.append("\n")

        for (i in 0..commands.size) {
            let cmd = commands[i]
            let desc = if (i < descriptions.size) { descriptions[i] } else { "" }
            sb.append("complete -c bao -n '__fish_use_subcommand' -a '${cmd}' -d '${desc}'\n")
        }

        sb.append("\n")
        for (flag in flags) {
            sb.append("complete -c bao -n '__fish_use_subcommand' -l '${flag.replaceStart("-")}'\n")
        }
        return sb.toString()
    }

    /// 生成 PowerShell 补全
    private func generatePwsh(): String {
        var sb = StringBuilder()
        sb.append("# Bao shell completions for PowerShell\n")
        sb.append("# Generated by `bao completions pwsh`\n")
        sb.append("\n")
        sb.append("Register-ArgumentCompleter -Native -CommandName bao -ScriptBlock {\n")
        sb.append("  param($commandName, $wordToComplete, $cursorPosition)\n")
        sb.append("  $commands = @(\n")
        for (i in 0..commands.size) {
            sb.append("    [CompletionResult]::new('${commands[i]}', '${commands[i]}', 'ParameterValue', '${if (i < descriptions.size) descriptions[i] else ""}')\n")
        }
        sb.append("  )\n")
        sb.append("  $commands | Where-Object { $_.CompletionText -like \"$wordToComplete*\" }\n")
        sb.append("}\n")
        return sb.toString()
    }
}

/// completions 命令执行器
/// 严格翻译自: src/cli/install_completions_command.zig
public class CompletionsCommand {
    private var logger: Logger

    public init() {
        logger = Logger()
    }

    /// 执行 completions 命令
    public func execute(args: ArrayList<String>): Unit {
        var shellType = CompletionsGenerator.detectShell()

        // 检查是否传了 shell 类型参数
        for (arg in args) {
            match (arg) {
                case "bash" => shellType = ShellType.Bash
                case "zsh" => shellType = ShellType.Zsh
                case "fish" => shellType = ShellType.Fish
                case "pwsh" | "powershell" => shellType = ShellType.Pwsh
                case "--help" | "-h" => {
                    printCompletionsHelp()
                    return
                }
                case _ => logger.warn("Unknown argument: ${arg}")
            }
        }

        if (shellType == ShellType.Unknown) {
            logger.error("Could not detect your shell. Please specify: bash, zsh, fish, or pwsh")
            logger.info("Usage: bao completions <shell>")
            return
        }

        let generator = CompletionsGenerator()
        generator.shell = shellType
        let script = generator.generate()

        if (script.isEmpty()) {
            logger.error("No completions available for the detected shell")
            return
        }

        print(script)
    }

    /// 打印帮助
    private func printCompletionsHelp(): Unit {
        println("Usage: bao completions <shell>")
        println("")
        println("Generate shell completions for Bao")
        println("")
        println("Supported shells:")
        println("  bash        Bash completions")
        println("  zsh         Zsh completions")
        println("  fish        Fish completions")
        println("  pwsh        PowerShell completions")
        println("")
        println("Examples:")
        println("  bao completions bash >> ~/.bashrc")
        println("  bao completions zsh >> ~/.zshrc")
        println("  bao completions fish > ~/.config/fish/completions/bao.fish")
    }
}

/// String 扩展辅助
public class StringBuilder {
    private var parts: ArrayList<String>

    public init() {
        parts = ArrayList<String>()
    }

    public func append(s: String): Unit {
        parts.append(s)
    }

    public func toString(): String {
        var result = ""
        for (p in parts) {
            result = result + p
        }
        return result
    }
}

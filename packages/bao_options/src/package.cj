// bao_options - 选项类型包
// 严格翻译自: bun/src/options_types/
//   BundleEnums.zig - 打包格式枚举
//   CommandTag.zig - CLI 命令标签
//   CompileTarget.zig - 编译目标
//   Context.zig - 命令上下文
//   GlobalCache.zig - 全局缓存策略
//   OfflineMode.zig - 离线模式
//   CodeCoverageOptions.zig - 代码覆盖率选项
//   import_record.zig - 导入记录类型
//   jsx.rs - JSX 转换选项 (Runtime, Pragma, ImportSource)
//   schema.rs - 序列化 schema API 类型 (Writer, Target, Loader, etc.)
package bao_options

import bao_core.*
import bao_collections.*

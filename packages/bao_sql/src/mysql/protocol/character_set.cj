// MySQL 协议字符集 (protocol 子目录副本)
// 对应 Bun: src/sql/mysql/protocol/CharacterSet.zig
//
// 注意: 此文件与 mysql_types.cj 中的 CharacterSet 相同，
// Bun 中 protocol/CharacterSet.zig 和 MySQLTypes.zig 中的定义也是相同的。
// 这里保持 1:1 对应，独立存放。
package bao_sql


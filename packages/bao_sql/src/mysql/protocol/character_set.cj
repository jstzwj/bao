    | unknown(UInt8)

    /// 默认字符集
    public static let defaultCharSet: ProtocolCharacterSet = ProtocolCharacterSet.utf8mb4_general_ci(45)

    /// 获取字符集标签名称
    public func label(): String {
        let val = this.toUInt8()
        if (val > 0 && val < 100) {
            return this.toString()
        }
        return "(unknown)"
    }

            case tigrinya_et_abegede_list_style_type => isCompatible_tigrinya_et_abegede_list_style_type(browsers)
            case tigrinya_et_list_style_type => isCompatible_tigrinya_et_list_style_type(browsers)
            case trad_chinese_formal_list_style_type => isCompatible_trad_chinese_formal_list_style_type(browsers)
            case trad_chinese_informal_list_style_type => isCompatible_trad_chinese_informal_list_style_type(browsers)
            case upper_alpha_list_style_type => isCompatible_upper_alpha_list_style_type(browsers)
            case upper_armenian_list_style_type => isCompatible_upper_armenian_list_style_type(browsers)
            case upper_hexadecimal_list_style_type => isCompatible_upper_hexadecimal_list_style_type(browsers)
            case upper_latin_list_style_type => isCompatible_upper_latin_list_style_type(browsers)
            case upper_norwegian_list_style_type => isCompatible_upper_norwegian_list_style_type(browsers)
            case upper_roman_list_style_type => isCompatible_upper_roman_list_style_type(browsers)
            case vb_unit => isCompatible_vb_unit(browsers)
            case vh_unit => isCompatible_vh_unit(browsers)
            case vi_unit => isCompatible_vi_unit(browsers)
            case viewport_percentage_units_dynamic => isCompatible_viewport_percentage_units_dynamic(browsers)
            case viewport_percentage_units_large => isCompatible_viewport_percentage_units_large(browsers)
            case viewport_percentage_units_small => isCompatible_viewport_percentage_units_small(browsers)
            case vmax_unit => isCompatible_vmax_unit(browsers)
            case vmin_unit => isCompatible_vmin_unit(browsers)
            case vw_unit => isCompatible_vw_unit(browsers)
            case webkit_fill_available_size => isCompatible_webkit_fill_available_size(browsers)
            case x_resolution_unit => isCompatible_x_resolution_unit(browsers)
        }
        return true
    }

    /// 检查特性是否被任一目标浏览器部分支持
    /// 严格翻译自 Feature.isPartiallyCompatible()
    public func isPartiallyCompatible(targets: CssBrowsers): Bool {
        var browsers = CssBrowsers()
        if (targets.android.isSome()) {
            browsers.android = targets.android
            if (isCompatible(browsers)) { return true }
            browsers.android = None
        }
        if (targets.chrome.isSome()) {
            browsers.chrome = targets.chrome
            if (isCompatible(browsers)) { return true }
            browsers.chrome = None
        }
        if (targets.edge.isSome()) {
            browsers.edge = targets.edge
            if (isCompatible(browsers)) { return true }
            browsers.edge = None
        }
        if (targets.firefox.isSome()) {
            browsers.firefox = targets.firefox
            if (isCompatible(browsers)) { return true }
            browsers.firefox = None
        }
        if (targets.ie.isSome()) {
            browsers.ie = targets.ie
            if (isCompatible(browsers)) { return true }
            browsers.ie = None
        }
        if (targets.ios_saf.isSome()) {
            browsers.ios_saf = targets.ios_saf
            if (isCompatible(browsers)) { return true }
            browsers.ios_saf = None
        }
        if (targets.opera.isSome()) {
            browsers.opera = targets.opera
            if (isCompatible(browsers)) { return true }
            browsers.opera = None
        }
        if (targets.safari.isSome()) {
            browsers.safari = targets.safari
            if (isCompatible(browsers)) { return true }
            browsers.safari = None
        }
        if (targets.samsung.isSome()) {
            browsers.samsung = targets.samsung
            if (isCompatible(browsers)) { return true }
            browsers.samsung = None
        }
        return false
    }
}


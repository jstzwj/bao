    (0x11145, 0x11146), (0x11182, 0x11182), (0x111B3, 0x111B5),
    (0x111BF, 0x111C0), (0x111CE, 0x111CE), (0x1122C, 0x1122E),
    (0x11232, 0x11233), (0x11235, 0x11235), (0x112E0, 0x112E2),
    (0x11302, 0x11303), (0x1133F, 0x1133F), (0x11341, 0x11344),
    (0x11347, 0x11348), (0x1134B, 0x1134D), (0x11362, 0x11363),
    (0x11435, 0x11437), (0x11440, 0x11441), (0x11445, 0x11445),
    (0x114B1, 0x114B2), (0x114B9, 0x114B9), (0x114BB, 0x114BC),
    (0x114BE, 0x114BE), (0x114C1, 0x114C1), (0x115B0, 0x115B1),
    (0x115B8, 0x115BB), (0x11630, 0x11632), (0x1163B, 0x1163C),
    (0x1163E, 0x1163E), (0x116AC, 0x116AC), (0x116AE, 0x116AF),
    (0x116B6, 0x116B6), (0x11720, 0x11721), (0x11726, 0x11726),
    (0x1182C, 0x1182E), (0x11838, 0x11838),
    (0x11931, 0x11935), (0x11937, 0x11938), (0x1193D, 0x1193D),
    (0x11940, 0x11940), (0x11942, 0x11942),
    (0x119D1, 0x119D3), (0x119DC, 0x119DF), (0x119E4, 0x119E4),
    (0x11A39, 0x11A39), (0x11A57, 0x11A58), (0x11A97, 0x11A97),
    (0x11C2F, 0x11C2F), (0x11C3E, 0x11C3E), (0x11CA9, 0x11CA9),
    (0x11CB1, 0x11CB1), (0x11CB4, 0x11CB4),
    (0x11D8A, 0x11D8E), (0x11D93, 0x11D94), (0x11D96, 0x11D96),
    (0x11EF5, 0x11EF6), (0x11F03, 0x11F03),
    (0x16F51, 0x16F87)
]

/// Me (Enclosing Mark) 范围
private let meRanges: Array<(UInt32, UInt32)> = [
    (0x0488, 0x0489), (0x1ABE, 0x1ABE), (0x20DD, 0x20E0),
    (0x20E2, 0x20E4), (0xA670, 0xA672)
]

// ============================================================================
// General Category 查询
// 严格翻译自 Bun uucode get(.general_category, cp)
// ============================================================================

/// 获取码点的 Unicode 通用类别
/// 严格翻译自 Bun uucode get(.general_category, cp)
public func generalCategory(cp: UInt32): GeneralCategory {
    // ASCII 快速路径
    if (cp <= 0x7F) {
        if (cp >= 65 && cp <= 90) { return GeneralCategory.Lu }
        if (cp >= 97 && cp <= 122) { return GeneralCategory.Ll }
        if (cp >= 48 && cp <= 57) { return GeneralCategory.Nd }
        if (cp <= 0x1F || cp == 0x7F) { return GeneralCategory.Cc }
        if (cp == 32) { return GeneralCategory.Zs }
        // Symbols and punctuation
        if (cp == 33 || cp == 34 || cp == 35 ||
            cp == 37 || cp == 38 || cp == 39) {
            return GeneralCategory.Po
        }
        if (cp == 40) { return GeneralCategory.Ps }
        if (cp == 41) { return GeneralCategory.Pe }
        if (cp == 42) { return GeneralCategory.Po }
        if (cp == 43) { return GeneralCategory.Sm }
        if (cp == 44) { return GeneralCategory.Pd }
        if (cp == 45) { return GeneralCategory.Pd }
        if (cp == 46) { return GeneralCategory.Po }
        if (cp == 47) { return GeneralCategory.Po }
        if (cp == 58) { return GeneralCategory.Po }
        if (cp == 59) { return GeneralCategory.Po }
        if (cp == 60) { return GeneralCategory.Sm }
        if (cp == 61) { return GeneralCategory.Sm }
        if (cp == 62) { return GeneralCategory.Sm }
        if (cp == 63) { return GeneralCategory.Po }
        if (cp == 64) { return GeneralCategory.Po }
        if (cp == 91) { return GeneralCategory.Ps }
        if (cp == 92) { return GeneralCategory.Po }
        if (cp == 93) { return GeneralCategory.Pe }
        if (cp == 94) { return GeneralCategory.Sm }
        if (cp == 95) { return GeneralCategory.Pc }
        if (cp == 96) { return GeneralCategory.Sk }
        if (cp == 123) { return GeneralCategory.Ps }
        if (cp == 124) { return GeneralCategory.Sm }
        if (cp == 125) { return GeneralCategory.Pe }
        if (cp == 126) { return GeneralCategory.Sm }
        return GeneralCategory.Cn
    }

    // 高效查找: 先检查最常见的类别
    if (binarySearchRange(ccRanges, cp)) { return GeneralCategory.Cc }
    if (binarySearchRange(csRanges, cp)) { return GeneralCategory.Cs }
    if (binarySearchRange(coRanges, cp)) { return GeneralCategory.Co }
    if (binarySearchRange(cfRanges, cp)) { return GeneralCategory.Cf }
    if (binarySearchRange(zsRanges, cp)) { return GeneralCategory.Zs }
    if (binarySearchRange(zlRanges, cp)) { return GeneralCategory.Zl }
    if (binarySearchRange(zpRanges, cp)) { return GeneralCategory.Zp }
    if (binarySearchRange(ndRanges, cp)) { return GeneralCategory.Nd }
    if (binarySearchRange(mnRanges, cp)) { return GeneralCategory.Mn }
    if (binarySearchRange(mcRanges, cp)) { return GeneralCategory.Mc }
    if (binarySearchRange(meRanges, cp)) { return GeneralCategory.Me }
    if (binarySearchRange(luRanges, cp)) { return GeneralCategory.Lu }
    if (binarySearchRange(llRanges, cp)) { return GeneralCategory.Ll }
    if (binarySearchRange(smRanges, cp)) { return GeneralCategory.Sm }
    if (binarySearchRange(scRanges, cp)) { return GeneralCategory.Sc }
    if (binarySearchRange(pcRanges, cp)) { return GeneralCategory.Pc }
    if (binarySearchRange(loRanges, cp)) { return GeneralCategory.Lo }

    // 超出 Unicode 范围
    if (cp > MAX_CODE_POINT) { return GeneralCategory.Cn }

    return GeneralCategory.Cn
}

// ============================================================================
// 便捷查询函数
// ============================================================================

/// 判断码点是否为字母
public func isLetter(cp: UInt32): Bool {
    let gc = generalCategory(cp)
    return gc == GeneralCategory.Lu || gc == GeneralCategory.Ll ||
           gc == GeneralCategory.Lt || gc == GeneralCategory.Lm ||
           gc == GeneralCategory.Lo
}

/// 判断码点是否为数字
public func isDigit(cp: UInt32): Bool {
    return generalCategory(cp) == GeneralCategory.Nd
}

/// 判断码点是否为字母或数字
public func isAlphaNumeric(cp: UInt32): Bool {
    let gc = generalCategory(cp)
    return gc == GeneralCategory.Lu || gc == GeneralCategory.Ll ||
           gc == GeneralCategory.Lt || gc == GeneralCategory.Lm ||
           gc == GeneralCategory.Lo || gc == GeneralCategory.Nd ||
           gc == GeneralCategory.Nl || gc == GeneralCategory.No
}

/// 判断码点是否为标点
public func isPunctuation(cp: UInt32): Bool {
    let gc = generalCategory(cp)
    return gc == GeneralCategory.Pc || gc == GeneralCategory.Pd ||
           gc == GeneralCategory.Ps || gc == GeneralCategory.Pe ||
           gc == GeneralCategory.Pi || gc == GeneralCategory.Pf ||
           gc == GeneralCategory.Po
}

/// 判断码点是否为符号
public func isSymbol(cp: UInt32): Bool {
    let gc = generalCategory(cp)
    return gc == GeneralCategory.Sm || gc == GeneralCategory.Sc ||
           gc == GeneralCategory.Sk || gc == GeneralCategory.So
}

/// 判断码点是否为控制字符
public func isControl(cp: UInt32): Bool {
    return generalCategory(cp) == GeneralCategory.Cc
}

/// 判断码点是否为空格类字符 (Zs)
public func isSpace(cp: UInt32): Bool {
    return generalCategory(cp) == GeneralCategory.Zs
}

/// 判断码点是否为大写字母
public func isUpperCase(cp: UInt32): Bool {
    return generalCategory(cp) == GeneralCategory.Lu
}

/// 判断码点是否为小写字母
public func isLowerCase(cp: UInt32): Bool {
    return generalCategory(cp) == GeneralCategory.Ll
}

/// 判断码点是否为标记字符
public func isMark(cp: UInt32): Bool {
    let gc = generalCategory(cp)
    return gc == GeneralCategory.Mn || gc == GeneralCategory.Mc ||
           gc == GeneralCategory.Me
}

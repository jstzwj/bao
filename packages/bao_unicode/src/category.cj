// bao_unicode - Unicode 通用类别
// 严格翻译自: src/unicode/uucode_lib/src/types.zig GeneralCategory + get.zig
//   Bun 使用 3 级查找表 (stage1/stage2/stage3) 映射码点到 GeneralCategory
//   仓颉实现使用排序的范围表 + 二分查找
package bao_unicode

// ============================================================================
// General Category 范围查找表
// 严格翻译自 Unicode 15.0 UnicodeData.txt
//   格式: Array<(start, end, category_ordinal)>
//   category_ordinal 对应 GeneralCategory 枚举值顺序
// ============================================================================

